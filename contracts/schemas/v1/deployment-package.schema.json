{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.mobile-framework.local/v1/deployment-package.schema.json",
  "title": "Deployment Package",
  "description": "Immutable signed mobile configuration package shape.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "package_id",
    "tenant_id",
    "app_id",
    "app_version",
    "runtime_min_version",
    "runtime_max_version",
    "modules",
    "theme",
    "app",
    "forms",
    "created_at",
    "created_by",
    "hash",
    "signature"
  ],
  "properties": {
    "schema_version": { "const": "v1" },
    "package_id": { "$ref": "#/$defs/id" },
    "tenant_id": { "$ref": "#/$defs/id" },
    "app_id": { "$ref": "#/$defs/id" },
    "app_version": { "$ref": "#/$defs/semver" },
    "runtime_min_version": { "$ref": "#/$defs/semver" },
    "runtime_max_version": { "$ref": "#/$defs/semver" },
    "platform_version": { "$ref": "#/$defs/semver" },
    "channel": {
      "type": "string",
      "enum": ["dev", "test", "staging", "production"]
    },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "https://schemas.mobile-framework.local/v1/module-manifest.schema.json" }
    },
    "theme": { "$ref": "https://schemas.mobile-framework.local/v1/theme.schema.json" },
    "app": { "$ref": "https://schemas.mobile-framework.local/v1/app.schema.json" },
    "forms": {
      "type": "array",
      "items": { "$ref": "https://schemas.mobile-framework.local/v1/form.schema.json" },
      "default": []
    },
    "assets": {
      "type": "array",
      "items": { "$ref": "#/$defs/asset" },
      "default": []
    },
    "sync_rules": {
      "type": "array",
      "items": { "$ref": "https://schemas.mobile-framework.local/v1/sync-rule.schema.json" },
      "default": []
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "signature": {
      "type": "string",
      "minLength": 32,
      "maxLength": 1000
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$",
      "minLength": 2,
      "maxLength": 100
    },
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:[-+][0-9A-Za-z.-]+)?$"
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["asset_id", "asset_type", "uri", "hash"],
      "properties": {
        "asset_id": { "$ref": "#/$defs/id" },
        "asset_type": {
          "type": "string",
          "enum": ["image", "font", "document", "other"]
        },
        "uri": {
          "type": "string",
          "format": "uri",
          "maxLength": 500
        },
        "hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    }
  }
}
