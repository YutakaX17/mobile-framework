{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.mobile-framework.local/v1/app.schema.json",
  "title": "App Definition",
  "description": "Top-level mobile app definition containing navigation, screens, permissions, and package references.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "app_id", "name", "version", "navigation", "screens"],
  "properties": {
    "schema_version": { "const": "v1" },
    "app_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$",
      "minLength": 2,
      "maxLength": 80
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "description": {
      "type": "string",
      "maxLength": 1000
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:[-+][0-9A-Za-z.-]+)?$"
    },
    "theme_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$",
      "maxLength": 80
    },
    "navigation": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/navigation_item" }
    },
    "screens": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "https://schemas.mobile-framework.local/v1/screen.schema.json" }
    },
    "permissions": {
      "type": "array",
      "items": { "$ref": "#/$defs/permission" },
      "default": []
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "navigation_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "screen_id"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "screen_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$",
          "maxLength": 80
        },
        "icon": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$",
          "maxLength": 80
        },
        "permission": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:\\.[a-z][a-z0-9_]*)+$",
          "maxLength": 120
        }
      }
    },
    "permission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "label"],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:\\.[a-z][a-z0-9_]*)+$",
          "maxLength": 120
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        }
      }
    }
  }
}
