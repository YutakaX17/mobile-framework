{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.mobile-framework.local/v1/sync-rule.schema.json",
  "title": "Sync Rule",
  "description": "Mobile sync rule definition for offline pull, outbox push, conflict handling, retries, and audit behavior.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "sync_rule_id", "name", "entity_type", "direction", "conflict_policy"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "sync_rule_id": { "$ref": "#/$defs/id" },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "description": {
      "type": "string",
      "maxLength": 500
    },
    "entity_type": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:\\.[a-z][a-z0-9_]*)*$",
      "minLength": 2,
      "maxLength": 120
    },
    "direction": {
      "type": "string",
      "enum": ["pull", "push", "bidirectional"]
    },
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "priority": {
      "type": "integer",
      "minimum": 0,
      "maximum": 1000,
      "default": 100
    },
    "pull": { "$ref": "#/$defs/pull" },
    "push": { "$ref": "#/$defs/push" },
    "conflict_policy": {
      "type": "string",
      "enum": ["server_wins", "client_wins", "manual_review", "reject"]
    },
    "conflict": { "$ref": "#/$defs/conflict" },
    "retry_policy": { "$ref": "#/$defs/retry_policy" },
    "audit": { "$ref": "#/$defs/audit" },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "log_success": {
          "type": "boolean",
          "default": false
        },
        "log_rejections": {
          "type": "boolean",
          "default": true
        },
        "log_conflicts": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "conflict": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "detect_with": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/field_path" }
        },
        "manual_review_queue": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$",
          "maxLength": 80
        },
        "stale_after_seconds": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2592000
        }
      }
    },
    "field_path": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(?:\\.[a-z][a-z0-9_]*)*$",
      "minLength": 1,
      "maxLength": 200
    },
    "filter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "operator", "value"],
      "properties": {
        "field": { "$ref": "#/$defs/field_path" },
        "operator": {
          "type": "string",
          "enum": ["eq", "neq", "in", "not_in", "gt", "gte", "lt", "lte"]
        },
        "value": {
          "type": ["string", "number", "boolean", "array", "null"]
        }
      }
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$",
      "minLength": 2,
      "maxLength": 80
    },
    "pull": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy"],
      "properties": {
        "strategy": {
          "type": "string",
          "enum": ["full_snapshot", "incremental_cursor"]
        },
        "cursor_field": { "$ref": "#/$defs/field_path" },
        "include_deleted": {
          "type": "boolean",
          "default": true
        },
        "page_size": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000,
          "default": 100
        },
        "filters": {
          "type": "array",
          "items": { "$ref": "#/$defs/filter" },
          "default": []
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "strategy": { "const": "incremental_cursor" } },
            "required": ["strategy"]
          },
          "then": { "required": ["cursor_field"] }
        }
      ]
    },
    "push": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operations"],
      "properties": {
        "operations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["create", "update", "delete", "submit"]
          }
        },
        "batch_size": {
          "type": "integer",
          "minimum": 1,
          "maximum": 500,
          "default": 50
        },
        "idempotency_key_fields": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/field_path" }
        },
        "requires_network": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "retry_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_attempts": {
          "type": "integer",
          "minimum": 0,
          "maximum": 20,
          "default": 5
        },
        "backoff_seconds": {
          "type": "integer",
          "minimum": 0,
          "maximum": 86400,
          "default": 30
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "direction": { "const": "pull" } },
        "required": ["direction"]
      },
      "then": { "required": ["pull"] }
    },
    {
      "if": {
        "properties": { "direction": { "const": "push" } },
        "required": ["direction"]
      },
      "then": { "required": ["push"] }
    },
    {
      "if": {
        "properties": { "direction": { "const": "bidirectional" } },
        "required": ["direction"]
      },
      "then": { "required": ["pull", "push"] }
    }
  ]
}
