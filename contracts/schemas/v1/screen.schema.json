{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.mobile-framework.local/v1/screen.schema.json",
  "title": "Screen",
  "description": "Dynamic screen definition for mobile runtime rendering.",
  "type": "object",
  "additionalProperties": false,
  "required": ["screen_id", "name", "screen_type", "components"],
  "properties": {
    "screen_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$",
      "minLength": 2,
      "maxLength": 80
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "screen_type": {
      "type": "string",
      "enum": ["dashboard", "form", "detail", "list", "settings", "custom"]
    },
    "route": {
      "type": "string",
      "pattern": "^/[a-z0-9_/-]*$",
      "maxLength": 200
    },
    "permission": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:\\.[a-z][a-z0-9_]*)+$",
      "maxLength": 120
    },
    "layout": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["single_column", "two_column", "list", "card_grid"]
        }
      }
    },
    "components": {
      "type": "array",
      "items": { "$ref": "https://schemas.mobile-framework.local/v1/component.schema.json" },
      "minItems": 1
    },
    "actions": {
      "type": "array",
      "items": { "$ref": "https://schemas.mobile-framework.local/v1/action.schema.json" },
      "default": []
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "screen_type": { "const": "form" } },
        "required": ["screen_type"]
      },
      "then": {
        "properties": {
          "components": {
            "contains": {
              "type": "object",
              "properties": { "component_type": { "const": "form" } },
              "required": ["component_type"]
            }
          }
        }
      }
    }
  ]
}
