{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.mobile-framework.local/v1/mobile-form-submission.schema.json",
  "title": "Mobile Form Submission",
  "description": "Offline-capable mobile form submission payload contract for outbox storage and sync replay.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "local_id", "device_id", "form_id", "revision", "submitted_at", "answers"],
  "properties": {
    "schema_version": {
      "const": "v1"
    },
    "local_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
      "minLength": 2,
      "maxLength": 80
    },
    "device_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
      "minLength": 2,
      "maxLength": 120
    },
    "form_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$",
      "minLength": 2,
      "maxLength": 80
    },
    "revision": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000000
    },
    "submitted_at": {
      "type": "string",
      "format": "date-time"
    },
    "answers": {
      "type": "object",
      "additionalProperties": true
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    }
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "app_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$",
          "minLength": 2,
          "maxLength": 80
        },
        "package_version": {
          "type": "string",
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:[-+][0-9A-Za-z.-]+)?$"
        },
        "screen_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$",
          "minLength": 2,
          "maxLength": 80
        }
      }
    }
  }
}
